---
interface Props {
  href?: string;
  class?: string;
  compact?: boolean;
}

const { href, class: className = "", compact = false } = Astro.props;
const Element = href ? "a" : "button";
---

<Element
  href={href}
  class:list={[
    "flex cursor-pointer items-center justify-center whitespace-nowrap",
    !compact && "px-8 py-4",
    "rounded-xs bg-black text-sm font-bold tracking-widest text-white",
    "relative z-1 overflow-hidden transition-transform duration-200 ease-in-out",
    "before:absolute before:top-0 before:left-0 before:block before:h-[200%] before:w-full before:content-['']",
    "before:translate-y-1/2 before:scale-70 before:rounded-full before:bg-zinc-800",
    "before:-z-10 before:transition-all before:duration-250 before:ease-in-out",
    "active:before:-translate-y-1/6 active:before:scale-x-200 active:before:scale-y-100",
    "hover:before:-translate-y-1/6 hover:before:scale-x-200 hover:before:scale-y-100",
    className,
  ]}
>
  <slot />
</Element>

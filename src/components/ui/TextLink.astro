---
interface Props {
  href: string;
  class?: string;
  ariaLabel?: string;
}

const { href, class: className = "", ariaLabel } = Astro.props;
---

<a
  href={href}
  aria-label={ariaLabel}
  class:list={[
    "underline decoration-current transition-colors duration-200 ease-in-out",
    "hover:decoration-transparent active:decoration-transparent",
    className,
  ]}
>
  <slot />
</a>

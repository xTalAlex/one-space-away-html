---
interface Props {
  href?: string;
  class?: string;
  innerClass?: string;
}

const { href, class: className = "", innerClass = "" } = Astro.props;
const Element = href ? "a" : "button";
const content = await Astro.slots.render("default");
---

<Element
  href={href}
  class:list={["group relative overflow-hidden h-auto", className]}
>
  <span
    class:list={[
      "block relative overflow-hidden py-1.5 transition-all duration-300 ease-in-out will-change-transform",
      "group-active:opacity-0 group-active:-translate-y-full group-active:-skew-y-10",
      "group-hover:opacity-0 group-hover:-translate-y-full group-hover:-skew-y-10",
      innerClass,
    ]}
    set:html={content}
  />
  <span
    class:list={[
      "block absolute top-0 left-0 opacity-0 translate-y-full skew-y-10 overflow-hidden py-1.5 transition-all duration-300 ease-in-out will-change-transform",
      "group-active:opacity-100 group-active:translate-y-0 group-active:skew-y-0",
      "group-hover:opacity-100 group-hover:translate-y-0 group-hover:skew-y-0",
      innerClass,
    ]}
    aria-hidden="true"
    set:html={content}
  />
</Element>

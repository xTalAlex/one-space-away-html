---
import ButtonSecondary from "@components/ui/ButtonSecondary.astro";

import { t } from "../i18n";
---

<header
  id="header"
  class="fixed top-0 left-0 z-50 flex h-20 w-full px-4 transition-all duration-200 ease-in-out lg:px-8 [&.scrolled]:h-16 [&.scrolled]:bg-white/95 [&.scrolled]:shadow-sm [&.scrolled]:backdrop-blur-[10px]"
>
  <div
    id="mobile-overlay"
    class="invisible fixed top-0 left-0 z-50 h-screen w-full bg-black/50 opacity-0 backdrop-blur-sm transition-all duration-300 ease-in-out [&.active]:visible [&.active]:opacity-100"
  >
  </div>
  <nav
    class="relative mx-auto flex w-full max-w-7xl items-center justify-between text-base font-medium"
    role="navigation"
    aria-label="Main navigation"
  >
    <div>
      <a href="/" aria-label="One Space Away home">
        {t.header.logo}
      </a>
    </div>

    <div
      id="nav-content"
      class="max-lg:fixed max-lg:top-0 max-lg:-right-full max-lg:z-50 max-lg:h-screen max-lg:w-full max-lg:max-w-75 max-lg:flex-col max-lg:justify-start max-lg:bg-white max-lg:px-4 max-lg:pt-28 max-lg:pb-8 max-lg:shadow-[-5px_0_15px_rgba(0,0,0,0.1)] max-lg:transition-[right] max-lg:duration-300 max-lg:ease-in-out [&.active]:right-0"
    >
      <ul
        class="flex max-lg:mb-10 max-lg:flex-col max-lg:justify-start max-lg:gap-5"
      >
        <li class="lg:mx-4">
          <a
            href="/"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.home}</a
          >
        </li>
        <li class="lg:mx-4">
          <a
            href="/#portfolio"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.portfolio}</a
          >
        </li>
        <li class="lg:mx-4">
          <a
            href="/#how-it-works"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.howItWorks}</a
          >
        </li>
        <li class="lg:mx-4">
          <a
            href="/#about"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.about}</a
          >
        </li>

        <li class="lg:mx-4">
          <a
            href="/#contact"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.contact}</a
          >
        </li>
      </ul>

      <ButtonSecondary
        href="/#contact"
        class="nav-link inline-block hover:opacity-100 lg:hidden"
        innerClass="border-b-2 border-b-current text-base block"
      >
        {t.header.cta}
      </ButtonSecondary>
    </div>

    <!-- Desktop CTA -->
    <ButtonSecondary
      href="/#contact"
      class="nav-link hidden hover:opacity-100 lg:inline-block"
      innerClass="border-b-2 border-b-current text-base block"
    >
      {t.header.cta}
    </ButtonSecondary>

    <button
      id="hamburger"
      class="group z-50 flex h-5 w-7 cursor-pointer appearance-none flex-col justify-between lg:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span
        class="block h-0.5 w-full bg-current transition-transform duration-250 ease-in-out group-[.active]:translate-y-2 group-[.active]:rotate-45"
      ></span>
      <span
        class="block h-0.5 w-full bg-current transition-transform duration-250 ease-in-out group-[.active]:opacity-0"
      ></span>
      <span
        class="block h-0.5 w-full bg-current transition-transform duration-250 ease-in-out group-[.active]:-translate-y-2 group-[.active]:-rotate-45"
      ></span>
    </button>
  </nav>
</header>

<div id="trigger" class="h-px"></div>

<script>
  import { initHeaderObserver } from "@utils/headerObserver";
  import { initMobileMenu } from "@utils/mobileMenu";

  let headerCleanup = initHeaderObserver();
  let menuCleanup = initMobileMenu();

  document.addEventListener("astro:after-swap", () => {
    headerCleanup?.();
    menuCleanup?.();
    headerCleanup = initHeaderObserver();
    menuCleanup = initMobileMenu();
  });
</script>

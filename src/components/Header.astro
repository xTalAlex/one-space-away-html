---
import ButtonSecondary from "@src/components/ui/ButtonSecondary.astro";
import { t } from "@src/i18n";
---

<header
  id="header"
  x-data="{ open: false }"
  x-on:keydown.escape.window="open = false"
  x-bind:class="{ 'h-16 bg-white/95 shadow-sm': $store.header.scrolled, 'h-20': !$store.header.scrolled }"
  class="fixed top-0 left-0 z-50 flex h-20 w-full px-4 transition-all duration-200 ease-in-out lg:px-8"
>
  <div
    x-show="open"
    x-transition:enter="transition duration-300 ease-in-out"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition duration-300 ease-in-out"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    x-on:click="open = false"
    class="fixed top-0 left-0 z-50 h-screen w-full bg-black/50 backdrop-blur-sm"
    x-cloak
  >
  </div>
  <nav
    class="relative mx-auto flex w-full max-w-7xl items-center justify-between text-base font-medium"
    role="navigation"
    aria-label="Main navigation"
  >
    <div>
      <a href="/" aria-label="One Space Away home">
        {t.header.logo}
      </a>
    </div>

    <div
      x-bind:class="open ? 'right-0' : '-right-full'"
      class="-right-full max-lg:fixed max-lg:top-0 max-lg:z-50 max-lg:h-screen max-lg:w-full max-lg:max-w-75 max-lg:flex-col max-lg:justify-start max-lg:bg-white max-lg:px-4 max-lg:pt-28 max-lg:pb-8 max-lg:shadow-lg max-lg:transition-[right] max-lg:duration-300 max-lg:ease-in-out"
    >
      <ul
        class="flex max-lg:mb-10 max-lg:flex-col max-lg:justify-start max-lg:gap-5"
      >
        <li class="lg:mx-4">
          <a
            href="/#portfolio"
            x-on:click="open = false"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.portfolio}</a
          >
        </li>
        <li class="lg:mx-4">
          <a
            href="/#how-it-works"
            x-on:click="open = false"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.howItWorks}</a
          >
        </li>
        <li class="lg:mx-4">
          <a
            href="/#about"
            x-on:click="open = false"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.about}</a
          >
        </li>

        <li class="lg:mx-4">
          <a
            href="/#contact"
            x-on:click="open = false"
            class="nav-link flex text-xl opacity-65 transition-all duration-200 ease-out hover:opacity-100 active:scale-95 active:opacity-100 lg:text-base"
            >{t.header.nav.contact}</a
          >
        </li>
      </ul>

      <ButtonSecondary
        href="/#contact"
        x-on:click="open = false"
        class="nav-link inline-block hover:opacity-100 lg:hidden"
        innerClass="border-b-2 border-b-current text-base block"
      >
        {t.header.cta}
      </ButtonSecondary>
    </div>

    <!-- Desktop CTA -->
    <ButtonSecondary
      href="/#contact"
      class="nav-link hidden hover:opacity-100 lg:inline-block"
      innerClass="border-b-2 border-b-current text-base block"
    >
      {t.header.cta}
    </ButtonSecondary>

    <button
      type="button"
      x-on:click="open = !open"
      x-bind:aria-expanded="open"
      class="z-50 flex h-5 w-7 cursor-pointer appearance-none flex-col justify-between lg:hidden"
      aria-label="Toggle menu"
    >
      <span
        x-bind:class="open && 'translate-y-2 rotate-45'"
        class="block h-0.5 w-full bg-current transition-transform duration-250 ease-in-out"
      ></span>
      <span
        x-bind:class="open && 'opacity-0'"
        class="block h-0.5 w-full bg-current transition-transform duration-250 ease-in-out"
      ></span>
      <span
        x-bind:class="open && '-translate-y-2 -rotate-45'"
        class="block h-0.5 w-full bg-current transition-transform duration-250 ease-in-out"
      ></span>
    </button>
  </nav>
</header>

<div
  id="header-trigger"
  x-data
  x-intersect:leave="$store.header.scrolled = true"
  x-intersect:enter="$store.header.scrolled = false"
  class="h-px"
>
</div>

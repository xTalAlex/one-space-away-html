---
import { Image } from "astro:assets";
import twoWomenSittingImage from "/src/assets/images/two-women-sitting.png";
import { t } from "../i18n";
---

<section id="about" class="about">
  <div class="section-container">
    <span class="section-tag">{t.about.tag}</span>
    <h2 class="section-title">{t.about.title}</h2>
    <div class="about-container">
      <div class="about-image-wrapper">
        <Image
          src={twoWomenSittingImage}
          alt="Two women sitting and talking about interior design."
          class="media"
        />
      </div>
      <div class="about-content">
        {
          t.about.items.map((content) => (
            <>
              <h3 class="section-subtitle about-subtitle">{content.title}</h3>
              <p class="about-text">{content.text}</p>
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--px-64);
    align-items: center;
  }

  .about-image-wrapper {
    width: 100%;
    height: 100%;
    min-height: 28.125rem;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .about-content {
    max-width: 37.5rem;
  }

  .about-text {
    margin-bottom: var(--px-32);
  }

  .about-text:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 64rem) {
    .about-container {
      gap: var(--px-32);
    }

    .about-image-wrapper {
      min-height: 25rem;
    }

    .about-content {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 48rem) {
    .about-container {
      grid-template-columns: 1fr;
      gap: var(--px-32);
    }

    .about-image-wrapper {
      min-height: 21.875rem;
      order: -1;
    }
  }
</style>

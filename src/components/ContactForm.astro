---
import ButtonPrimary from "@src/components/ui/ButtonPrimary.astro";
import TextLink from "@src/components/ui/TextLink.astro";
import { t } from "@src/i18n";

interface Props {
  termsHref: string;
  privacyHref: string;
}

const { termsHref, privacyHref } = Astro.props;

const disclaimerLinks = {
  "{terms}": { href: termsHref, label: t.footer.links.termsConditions },
  "{privacy}": { href: privacyHref, label: t.footer.links.privacyPolicy },
};

const disclaimerParts = t.contact.form.disclaimer.split(
  /(\{terms\}|\{privacy\})/,
);
---

<form
  id="contact-form"
  x-data="{ sending: false, sent: false }"
  x-on:submit.prevent="
    sending = true;
    await new Promise(r => setTimeout(r, 1500));
    sent = true;
    sending = false;
    $el.reset();
    setTimeout(() => sent = false, 4000);
  "
  class="lg:mr-12"
  action=""
>
  <div class="mb-10 grid grid-cols-1 gap-6 xl:grid-cols-2">
    <div class="grid gap-2">
      <label class="text-lg font-medium" for="name">{t.contact.form.name}</label
      >
      <input
        class="border border-black/20 px-5 py-4 text-base shadow-none transition-all duration-200 ease-out hover:border-black/40 focus:border-black/70 focus:text-black focus:shadow-sm focus:outline-none"
        id="name"
        type="text"
        placeholder={t.contact.form.namePlaceholder}
        required
      />
    </div>
    <div class="grid gap-2">
      <label class="text-lg font-medium" for="email"
        >{t.contact.form.email}</label
      >
      <input
        class="border border-black/20 px-5 py-4 text-base shadow-none transition-all duration-200 ease-out hover:border-black/40 focus:border-black/70 focus:text-black focus:shadow-sm focus:outline-none"
        id="email"
        type="email"
        placeholder={t.contact.form.emailPlaceholder}
        required
      />
    </div>
    <div class="col-span-full grid gap-2">
      <label class="text-lg font-medium" for="message"
        >{t.contact.form.project}</label
      >
      <textarea
        class="border border-black/20 px-5 py-4 text-base shadow-none transition-all duration-200 ease-out hover:border-black/40 focus:border-black/70 focus:text-black focus:shadow-sm focus:outline-none"
        id="message"
        placeholder={t.contact.form.projectPlaceholder}
        rows="4"
        required></textarea>
    </div>
  </div>
  <div
    class="flex flex-col items-start gap-4 xl:flex-row xl:items-center xl:justify-between"
  >
    <ButtonPrimary x-bind:disabled="sending" class="grid">
      <span
        class="col-start-1 row-start-1"
        x-bind:class="sending && 'invisible'">{t.contact.form.submit}</span
      >
      <span
        x-show="sending"
        x-cloak
        class="col-start-1 row-start-1 flex items-center justify-center"
      >
        <span
          class="h-5 w-5 animate-spin rounded-full border-2 border-white/20 border-t-white"
        ></span>
      </span>
    </ButtonPrimary>
    <div class="max-w-80">
      <label class="flex items-start gap-2 text-xs">
        <input
          type="checkbox"
          id="consent"
          required
          class="mt-0.5 h-4 w-4 shrink-0 cursor-pointer accent-black"
        />
        <span>
          {
            disclaimerParts.map((part) => {
              const link =
                disclaimerLinks[part as keyof typeof disclaimerLinks];
              return link ? (
                <TextLink href={link.href}>{link.label}</TextLink>
              ) : (
                part
              );
            })
          }
        </span>
      </label>
    </div>
  </div>
  <div
    x-show="sent"
    x-transition
    x-cloak
    class="mt-6 font-medium text-green-800"
  >
    <p>{t.contact.form.successText}</p>
  </div>
</form>

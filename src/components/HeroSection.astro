---
import ButtonPrimary from "@src/components/ui/ButtonPrimary.astro";
import ButtonSecondary from "@src/components/ui/ButtonSecondary.astro";
import SectionWrapper from "@src/components/ui/SectionWrapper.astro";
import { Icon } from "astro-icon/components";
import { t } from "@src/i18n";
---

<SectionWrapper
  id="hero"
  class="hero flex min-h-auto items-center lg:min-h-screen"
  py="pb-14 pt-28"
  containerClass="w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center"
>
  <div class="lg:max-w-150">
    <h1
      class="mb-6 text-[clamp(2.125rem,6vw,4rem)] leading-[1.3] font-medium lg:mb-7 lg:leading-[1.2]"
    >
      {t.hero.title}
    </h1>
    <p
      class="mb-9 text-[clamp(1.25rem,2vw,1.375rem)] leading-relaxed opacity-80 lg:mb-12"
    >
      {t.hero.subtitle}
    </p>
    <div class="flex flex-wrap gap-x-8 gap-y-4 lg:gap-x-12">
      <ButtonPrimary href="#contact">{t.hero.cta.start}</ButtonPrimary>
      <ButtonSecondary
        href="#how-it-works"
        class="mt-1.75 h-9 font-medium"
        innerClass="flex items-center justify-center gap-2"
      >
        <Icon name="material-symbols-light:play-arrow" class="h-4" />
        {t.hero.cta.howItWorks}
      </ButtonSecondary>
    </div>
  </div>
  <div class="h-full min-h-80 w-full overflow-hidden lg:min-h-0">
    <video
      class="h-full w-full object-cover"
      preload="auto"
      poster="hero-video-poster.webp"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
    >
      <source
        src="https://res.cloudinary.com/dellp9a4z/video/upload/f_auto,q_auto,vc_vp9,w_1080/v1774623099/ik-video_esc1gl.webm"
        type="video/webm"
      />
    </video>
  </div>
</SectionWrapper>

---
import { t } from "../i18n";
import ButtonPrimary from "@components/ui/ButtonPrimary.astro";
import ButtonSecondary from "@components/ui/ButtonSecondary.astro";
import SectionWrapper from "@components/ui/SectionWrapper.astro";
---

<SectionWrapper
  id="hero"
  class="hero min-h-auto lg:min-h-screen flex items-center"
  py="pb-14 pt-28"
  containerClass="w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center"
>
    <div class="lg:max-w-150">
      <h1
        class="text-[clamp(2.125rem,6vw,4rem)] leading-[1.3] lg:leading-[1.2] mb-6 lg:mb-7 font-medium"
      >
        {t.hero.title}
      </h1>
      <p
        class="leading-relaxed opacity-80 text-[clamp(1.25rem,2vw,1.375rem)] mb-9 lg:mb-12"
      >
        {t.hero.subtitle}
      </p>
      <div class="flex gap-y-4 lg:gap-x-12 gap-x-8 flex-wrap">
        <ButtonPrimary href="#contact">{t.hero.cta.start}</ButtonPrimary>
        <ButtonSecondary
          href="#how-it-works"
          class="font-medium mt-1.75 h-9"
          innerClass="flex items-center justify-center gap-2"
        >
          <svg
            class="h-4"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 384 512"
            ><!--!Font Awesome Free 6.7.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc.-->
            <path
              d="M73 39c-14.8-9.1-33.4-9.4-48.5-.9S0 62.6 0 80L0 432c0 17.4 9.4 33.4 24.5 41.9s33.7 8.1 48.5-.9L361 297c14.3-8.7 23-24.2 23-41s-8.7-32.2-23-41L73 39z"
            ></path>
          </svg>
          {t.hero.cta.howItWorks}
        </ButtonSecondary>
      </div>
    </div>
    <div class="w-full h-full overflow-hidden min-h-80 lg:min-h-0">
      <video
        class="w-full h-full object-cover"
        preload="auto"
        poster="hero-video-poster.webp"
        autoplay
        loop
        muted
        playsinline
        aria-hidden="true"
      >
        <source
          src="https://res.cloudinary.com/dellp9a4z/video/upload/f_auto,q_auto,vc_vp9,w_1080/v1774623099/ik-video_esc1gl.webm"
          type="video/webm"
        />
      </video>
    </div>
  </SectionWrapper>

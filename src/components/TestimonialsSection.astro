---
import BaseSwiper from "@src/components/BaseSwiper.astro";
import SectionHeader from "@src/components/ui/SectionHeader.astro";
import SectionWrapper from "@src/components/ui/SectionWrapper.astro";
import { t } from "@src/i18n";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

import emmaImage from "/src/assets/images/emma.jpg";
import sarahJohnsonImage from "/src/assets/images/sarah-johnson.jpg";

const testimonials = [
  {
    id: 1,
    type: "image",
    client: {
      name: "Sarah Johnson",
      location: "Beverly Hills, California",
      image: sarahJohnsonImage,
    },
    content: t.testimonials.items[0].content,
  },
  {
    id: 2,
    type: "image",
    client: {
      name: "Emma Lewis",
      location: "Palm Beach, Florida",
      image: emmaImage,
    },
    content: t.testimonials.items[1].content,
  },
  {
    id: 3,
    type: "video",
    client: {
      name: "Charlotte Bennett",
      location: "Austin, Texas",
    },
    video: {
      src: "https://res.cloudinary.com/dellp9a4z/video/upload/v1774625626/charlotte_iy65kg.webm",
      poster: "testimonial-video-placeholder.webp",
    },
  },
];
---

<SectionWrapper id="testimonials">
  <SectionHeader tag={t.testimonials.tag} title={t.testimonials.title} />

  <BaseSwiper sliderName="testimonials" navigation={false}>
    {
      testimonials.map((testimonial) => (
        <div class="swiper-slide">
          <article
            class:list={[
              "flex h-full max-w-93 flex-col overflow-hidden rounded-lg",
              testimonial.type === "video" && "aspect-2/3 max-h-137.5",
            ]}
          >
            {testimonial.type === "image" ? (
              <>
                <div class="mt-8 mb-6 flex items-center gap-4 p-4 md:p-0">
                  <div class="h-20 w-20 shrink-0 overflow-hidden rounded-full">
                    <Image
                      class="h-full w-full object-cover"
                      src={testimonial.client.image as ImageMetadata}
                      alt={testimonial.client.name}
                      width={160}
                      height={160}
                    />
                  </div>
                  <div class="flex flex-col gap-1">
                    <cite class="text-xl font-semibold not-italic">
                      {testimonial.client.name}
                    </cite>
                    <span>{testimonial.client.location}</span>
                  </div>
                </div>
                <blockquote class="p-4 md:p-0">
                  <p>{testimonial.content}</p>
                </blockquote>
              </>
            ) : (
              <div
                id={`video-${testimonial.id}`}
                x-data="{ playing: false }"
                class="relative h-full w-full bg-black"
                x-bind:class="{ 'before:opacity-0': playing }"
                class:list={[
                  "before:absolute before:inset-0 before:bg-black/30 before:opacity-100 before:transition-opacity before:duration-300 before:ease-linear before:content-['']",
                ]}
              >
                <video
                  x-ref="video"
                  x-on:play="playing = true"
                  x-on:pause="playing = false"
                  x-on:ended="playing = false"
                  class="h-full w-full object-cover"
                  playsinline
                  loop
                  disablepictureinpicture
                  preload="none"
                  poster={testimonial.video?.poster}
                >
                  <source src={testimonial.video?.src} type="video/mp4" />
                  <track kind="captions" />
                </video>
                <div class="absolute top-2 right-2 left-3.5 flex items-center justify-between text-white md:top-2.5 md:right-4 md:left-4">
                  <div class="flex flex-col gap-1">
                    <cite class="text-xl font-semibold not-italic drop-shadow-sm">
                      {testimonial.client.name}
                    </cite>
                    <span class="drop-shadow-sm">
                      {testimonial.client.location}
                    </span>
                  </div>
                  <button
                    type="button"
                    x-on:click="$refs.video.paused ? $refs.video.play() : $refs.video.pause()"
                    class="flex size-10 cursor-pointer items-center justify-center rounded-full border-none bg-white text-black shadow-sm transition-all duration-300 hover:scale-110 hover:shadow-md"
                    aria-label="Toggle video playback"
                  >
                    <Icon
                      name="material-symbols-light:play-arrow"
                      x-show="!playing"
                      class="h-7 w-7"
                    />
                    <Icon
                      name="material-symbols-light:pause"
                      x-show="playing"
                      x-cloak
                      class="h-5 w-5"
                    />
                  </button>
                </div>
              </div>
            )}
          </article>
        </div>
      ))
    }
  </BaseSwiper>
</SectionWrapper>

<script>
  import { createSwiper } from "@src/utils/baseSwiper";

  function initTestimonialsSlider() {
    const styles = getComputedStyle(document.documentElement);
    const bp = (name: string) =>
      parseFloat(styles.getPropertyValue(`--breakpoint-${name}`)) * 16;

    const swiper = createSwiper("testimonials", {
      pagination: {
        el: ".testimonials-pagination",
        clickable: true,
      },
      breakpoints: {
        [bp("sm")]: { slidesPerView: 1, spaceBetween: 16 },
        [bp("md")]: { slidesPerView: 2, spaceBetween: 96 },
        [bp("lg")]: { slidesPerView: 2, spaceBetween: 76 },
        [bp("xl")]: { slidesPerView: 3, spaceBetween: 76, loop: false },
      },
      on: {
        init: (swiper) => {
          if (bp("xl") <= window.innerWidth) {
            swiper.disable();
            swiper.el.classList.add("-non-slider");
          }
        },
        resize: (swiper) => {
          if (bp("xl") <= window.innerWidth) {
            swiper.disable();
            swiper.el.classList.add("-non-slider");
          } else {
            swiper.enable();
            swiper.el.classList.remove("-non-slider");
          }
        },
      },
    });

    return () => swiper.destroy();
  }

  let cleanup = initTestimonialsSlider();

  document.addEventListener("astro:after-swap", () => {
    if (cleanup) cleanup();
    cleanup = initTestimonialsSlider();
  });
</script>

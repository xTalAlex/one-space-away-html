---
import SectionHeader from "@components/ui/SectionHeader.astro";
import SectionWrapper from "@components/ui/SectionWrapper.astro";
import { SITE } from "@consts";

import { t } from "../i18n";
import ContactForm from "./ContactForm.astro";
---

<SectionWrapper id="contact" class="grid" containerClass="grid">
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
    <div class="lg:mr-12">
      <SectionHeader tag={t.contact.tag} title={t.contact.title} />
    </div>

    <address class="mb-14 grid grid-cols-1 gap-6 not-italic sm:grid-cols-2">
      <div
        class:list={[
          "relative pl-6",
          "before:absolute before:top-0 before:left-0 before:h-full before:w-px before:bg-black/10 before:content-['']",
        ]}
      >
        <div class="relative mb-5 inline-grid">
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill-rule="evenodd"
            clip-rule="evenodd"
            class="w-12"
          >
            <path
              d="M24 21h-24v-18h24v18zm-23-16.477v15.477h22v-15.477l-10.999 10-11.001-10zm21.089-.523h-20.176l10.088 9.171 10.088-9.171z"
            ></path>
          </svg>
          <div class="absolute -top-1/12 -right-1/3 grid">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm3.445 17.827c-3.684 1.684-9.401-9.43-5.8-11.308l1.053-.519 1.746 3.409-1.042.513c-1.095.587 1.185 5.04 2.305 4.497l1.032-.505 1.76 3.397-1.054.516z"
              ></path>
            </svg>
          </div>
        </div>
        <h3 class="mb-3 text-xl font-medium">{t.contact.hello}</h3>
        <div>
          <a
            href=`mailto:${SITE.EMAIL}`
            class="mb-1.5 block text-base opacity-80 transition-opacity duration-200 ease-out hover:opacity-100 active:opacity-100"
            >{SITE.EMAIL}</a
          >
          <a
            href=`tel:${SITE.TELEPHONE}`
            class="block text-base opacity-80 transition-opacity duration-200 ease-out hover:opacity-100 active:opacity-100"
            >{SITE.TELEPHONE}</a
          >
        </div>
      </div>
      <div
        class:list={[
          "relative pl-6",
          "before:absolute before:top-0 before:left-0 before:h-full before:w-px before:bg-black/10 before:content-['']",
        ]}
      >
        <div class="relative mb-5 inline-grid">
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill-rule="evenodd"
            clip-rule="evenodd"
            class="w-12"
          >
            <path
              d="M12 10c-1.104 0-2-.896-2-2s.896-2 2-2 2 .896 2 2-.896 2-2 2m0-5c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3m-7 2.602c0-3.517 3.271-6.602 7-6.602s7 3.085 7 6.602c0 3.455-2.563 7.543-7 14.527-4.489-7.073-7-11.072-7-14.527m7-7.602c-4.198 0-8 3.403-8 7.602 0 4.198 3.469 9.21 8 16.398 4.531-7.188 8-12.2 8-16.398 0-4.199-3.801-7.602-8-7.602"
            ></path>
          </svg>
        </div>
        <h3 class="mb-3 text-xl font-medium">{t.contact.location}</h3>
        <a
          class="block text-base opacity-80 transition-opacity duration-200 ease-out hover:opacity-100 active:opacity-100"
          href=`https://maps.google.com/?q=${SITE.ADDRESS}`>{SITE.ADDRESS}</a
        >
      </div>
    </address>
  </div>
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
    <ContactForm termsHref="legal/terms" privacyHref="legal/privacy" />

    <div class="h-full w-full">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d52871.78694097431!2d-118.44073380549868!3d34.0826707144581!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2bc04d6d147ab%3A0xd6c7c379fd081ed1!2sBeverly%20Hills%2C%20CA%2C%20USA!5e0!3m2!1sen!2spl!4v1743960669502!5m2!1sen!2spl"
        title="Map showing location of Beverly Hills, California, USA"
        width="600"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="h-full min-h-75 w-full md:min-h-112"></iframe>
    </div>
  </div>
</SectionWrapper>

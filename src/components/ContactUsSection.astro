---
import { CONFIG } from "@consts";
import ContactForm from "@src/components/ContactForm.astro";
import SectionHeader from "@src/components/ui/SectionHeader.astro";
import SectionWrapper from "@src/components/ui/SectionWrapper.astro";
import { t } from "@src/i18n";
import { Icon } from "astro-icon/components";
---

<SectionWrapper id="contact" class="grid" containerClass="grid">
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
    <div class="lg:mr-12">
      <SectionHeader tag={t.contact.tag} title={t.contact.title} />
    </div>

    <address class="mb-14 grid grid-cols-1 gap-6 not-italic sm:grid-cols-2">
      <div
        class:list={[
          "relative pl-6",
          "before:absolute before:top-0 before:left-0 before:h-full before:w-px before:bg-black/10 before:content-['']",
        ]}
      >
        <div class="relative mb-5 inline-grid">
          <Icon
            name="material-symbols-light:mail-outline"
            class="h-12 w-12"
            aria-hidden="true"
          />
          <div class="absolute -top-1/12 -right-1/3 grid">
            <Icon
              name="material-symbols-light:call"
              class="h-6 w-6"
              aria-hidden="true"
            />
          </div>
        </div>
        <h3 class="mb-3 text-xl font-medium">{t.contact.hello}</h3>
        <div>
          <a
            href={`mailto:${CONFIG.email}`}
            class="mb-1.5 block text-base opacity-80 transition-opacity duration-200 ease-out hover:opacity-100 active:opacity-100"
            >{CONFIG.email}</a
          >
          <a
            href={`tel:${CONFIG.telephone}`}
            class="block text-base opacity-80 transition-opacity duration-200 ease-out hover:opacity-100 active:opacity-100"
            >{CONFIG.telephone}</a
          >
        </div>
      </div>
      <div
        class:list={[
          "relative pl-6",
          "before:absolute before:top-0 before:left-0 before:h-full before:w-px before:bg-black/10 before:content-['']",
        ]}
      >
        <div class="relative mb-5 inline-grid">
          <Icon
            name="material-symbols-light:location-on-outline"
            class="h-12 w-12"
            aria-hidden="true"
          />
        </div>
        <h3 class="mb-3 text-xl font-medium">{t.contact.location}</h3>
        <a
          class="block text-base opacity-80 transition-opacity duration-200 ease-out hover:opacity-100 active:opacity-100"
          href={`https://maps.google.com/?q=${CONFIG.address}`}
          >{CONFIG.address}</a
        >
      </div>
    </address>
  </div>
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
    <ContactForm termsHref="legal/terms" privacyHref="legal/privacy" />

    <div class="h-full w-full">
      <iframe
        src={`https://maps.google.com/maps?q=${CONFIG.address}&t=&z=15&ie=UTF8&iwloc=&output=embed`}
        title={`Google Maps - ${CONFIG.address}`}
        width="600"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="h-full min-h-75 w-full md:min-h-112"></iframe>
    </div>
  </div>
</SectionWrapper>

---
import { Image } from "astro:assets";
import consultationImage from "/src/assets/images/consultation.jpg";
import designImage from "/src/assets/images/design.jpg";
import transformImage from "/src/assets/images/transform.jpg";
import { t } from "../i18n";

const processSteps = [
  {
    id: 1,
    title: t.process.steps[0].title,
    description: t.process.steps[0].description,
    image: {
      src: consultationImage,
      alt: t.process.steps[0].imageAlt,
    },
  },
  {
    id: 2,
    title: t.process.steps[1].title,
    description: t.process.steps[1].description,
    image: {
      src: designImage,
      alt: t.process.steps[1].imageAlt,
    },
  },
  {
    id: 3,
    title: t.process.steps[2].title,
    description: t.process.steps[2].description,
    image: {
      src: transformImage,
      alt: t.process.steps[2].imageAlt,
    },
  },
];
---

<section id="how-it-works">
  <div class="section-container">
    <span class="section-tag">{t.process.tag}</span>
    <h2 class="section-title">{t.process.title}</h2>
    <div class="flex flex-col gap-16 md:max-lg:gap-9">
      {
        processSteps.map((step) => (
          <div class="flex flex-col md:flex-row gap-8 lg:gap-16 items-center even:md:flex-row-reverse">
            <div class="md:flex-1">
              <h3 class="section-subtitle">{step.title}</h3>
              <p class="max-w-125 md:max-lg:max-w-full">{step.description}</p>
            </div>
            <div class="md:flex-1 w-full h-full max-h-82.5 overflow-hidden">
              <Image
                src={step.image.src}
                alt={step.image.alt}
                width={1272}
                height={660}
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

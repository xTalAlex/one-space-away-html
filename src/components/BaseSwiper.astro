---
import "@src/styles/swiper-custom.css";

import ButtonPrimary from "@src/components/ui/ButtonPrimary.astro";
import { Icon } from "astro-icon/components";
import { t } from "@src/i18n";

interface Props {
  sliderName: string;
  navigation?: boolean;
  pagination?: boolean;
  beforeAfter?: boolean;
}

const {
  sliderName,
  navigation = true,
  pagination = true,
  beforeAfter = false,
} = Astro.props;
---

<div class={`${sliderName}-showcase`}>
  <!-- Before/After Toggle -->
  {
    beforeAfter && (
      <div class="mb-8 flex gap-4 px-0 md:px-16">
        <button
          type="button"
          class:list={[
            "toggle-btn relative cursor-pointer pb-0.5 text-xl font-medium opacity-55 transition-opacity duration-300 hover:opacity-100 [&.active]:opacity-100",
            "after:absolute after:-bottom-px after:left-0 after:block after:h-0.5 after:w-full after:origin-right after:scale-x-0 after:bg-current after:transition-transform after:duration-250 after:ease-out after:content-[''] hover:after:origin-left hover:after:scale-x-100 [&.active]:after:origin-left [&.active]:after:scale-x-100",
          ]}
          data-view="before"
        >
          {t.portfolio.before}
        </button>
        <button
          type="button"
          class:list={[
            "toggle-btn active relative cursor-pointer pb-0.5 text-xl font-medium opacity-55 transition-opacity duration-300 hover:opacity-100 [&.active]:opacity-100",
            "after:absolute after:-bottom-px after:left-0 after:block after:h-0.5 after:w-full after:origin-right after:scale-x-0 after:bg-current after:transition-transform after:duration-250 after:ease-out after:content-[''] hover:after:origin-left hover:after:scale-x-100 [&.active]:after:origin-left [&.active]:after:scale-x-100",
          ]}
          data-view="after"
        >
          {t.portfolio.after}
        </button>
      </div>
    )
  }

  <div class={`swiper ${sliderName}-swiper`}>
    <div class="swiper-wrapper">
      <slot />
    </div>

    <!-- Navigation -->
    {
      navigation && (
        <>
          <div class="absolute top-1/2 left-0 z-10 hidden h-12 w-12 -translate-y-1/2 items-center justify-center overflow-hidden rounded-full shadow-lg md:flex">
            <ButtonPrimary
              compact
              class={`nav-btn h-full w-full ${sliderName}-prev`}
              aria-label="Previous"
            >
              <Icon name="material-symbols-light:chevron-left" class="h-6 w-6" />
            </ButtonPrimary>
          </div>
          <div class="absolute top-1/2 right-0 z-10 hidden h-12 w-12 -translate-y-1/2 items-center justify-center overflow-hidden rounded-full shadow-lg md:flex">
            <ButtonPrimary
              compact
              class={`nav-btn h-full w-full ${sliderName}-next`}
              aria-label="Next"
            >
              <Icon name="material-symbols-light:chevron-right" class="h-6 w-6" />
            </ButtonPrimary>
          </div>
        </>
      )
    }
  </div>

  <!-- Pagination -->
  {pagination && <div class={`swiper-pagination ${sliderName}-pagination`} />}
</div>

---
import "@styles/swiper-custom.css";
import { t } from "../i18n";

interface Props {
  sliderName: string;
  navigation?: boolean;
  pagination?: boolean;
  beforeAfter?: boolean;
}

const {
  sliderName,
  navigation = true,
  pagination = true,
  beforeAfter = false,
} = Astro.props;
---

<div class={`${sliderName}-showcase`}>
  <!-- Before/After Toggle -->
  {
    beforeAfter && (
      <div class="flex gap-4 md:px-16 mb-8 px-0">
        <button
          class:list={[
            "toggle-btn text-xl font-medium cursor-pointer opacity-55 relative pb-0.5 transition-opacity duration-300 [&.active]:opacity-100 hover:opacity-100",
            "after:content-[''] after:block after:absolute after:left-0 after:-bottom-px after:w-full after:h-0.5 after:bg-current after:scale-x-0 after:origin-right after:transition-transform after:duration-250 after:ease-out [&.active]:after:scale-x-100 [&.active]:after:origin-left hover:after:scale-x-100 hover:after:origin-left",
          ]}
          data-view="before"
        >
          {t.portfolio.before}
        </button>
        <button
          class:list={[
            "toggle-btn active text-xl font-medium cursor-pointer opacity-55 relative pb-0.5 transition-opacity duration-300 [&.active]:opacity-100 hover:opacity-100",
            "after:content-[''] after:block after:absolute after:left-0 after:-bottom-px after:w-full after:h-0.5 after:bg-current after:scale-x-0 after:origin-right after:transition-transform after:duration-250 after:ease-out [&.active]:after:scale-x-100 [&.active]:after:origin-left hover:after:scale-x-100 hover:after:origin-left",
          ]}
          data-view="after"
        >
          {t.portfolio.after}
        </button>
      </div>
    )
  }

  <div class={`swiper ${sliderName}-swiper`}>
    <div class="swiper-wrapper">
      <slot />
    </div>

    <!-- Navigation -->
    {
      navigation && (
        <>
          <div class="absolute top-1/2 -translate-y-1/2 left-0 w-12 h-12 rounded-full overflow-hidden hidden md:flex items-center justify-center shadow-lg z-2 transition-all duration-400 ease-elastic">
            <button
              class={`nav-btn btn--primary w-full h-full flex items-center justify-center cursor-pointer bg-black text-white ${sliderName}-prev`}
              aria-label="Previous"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="w-6 h-6"
              >
                <path d="M15 18l-6-6 6-6" />
              </svg>
            </button>
          </div>
          <div class="absolute top-1/2 -translate-y-1/2 right-0 w-12 h-12 rounded-full overflow-hidden hidden md:flex items-center justify-center shadow-lg z-2 transition-all duration-400 ease-elastic">
            <button
              class={`nav-btn btn--primary w-full h-full flex items-center justify-center cursor-pointer bg-black text-white ${sliderName}-next`}
              aria-label="Next"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="w-6 h-6"
              >
                <path d="M9 18l6-6-6-6" />
              </svg>
            </button>
          </div>
        </>
      )
    }
  </div>

  <!-- Pagination -->
  {pagination && <div class={`swiper-pagination ${sliderName}-pagination`} />}
</div>

---
import "@src/styles/swiper-custom.css";

import ButtonPrimary from "@src/components/ui/ButtonPrimary.astro";
import { t } from "@src/i18n";
import { Icon } from "astro-icon/components";

interface Props {
  sliderName: string;
  navigation?: boolean;
  pagination?: boolean;
  beforeAfter?: boolean;
}

const {
  sliderName,
  navigation = true,
  pagination = true,
  beforeAfter = false,
} = Astro.props;
---

<div class={`${sliderName}-showcase`}>
  <!-- Before/After Toggle -->
  {
    beforeAfter && (
      <div
        id="portfolio-toggle"
        class="mb-8 flex gap-4 px-0 md:px-16"
        x-data="{ view: 'after' }"
      >
        <button
          type="button"
          x-on:click="view = 'before'; $dispatch('portfolio-view', { view: 'before' })"
          x-bind:class="view === 'before' ? 'opacity-100 after:origin-left after:scale-x-100' : 'opacity-55 after:origin-right after:scale-x-0'"
          class="relative cursor-pointer pb-0.5 text-xl font-medium transition-opacity duration-300 after:absolute after:-bottom-px after:left-0 after:block after:h-0.5 after:w-full after:bg-current after:transition-transform after:duration-250 after:ease-out after:content-[''] hover:opacity-100 hover:after:origin-left hover:after:scale-x-100"
        >
          {t.portfolio.before}
        </button>
        <button
          type="button"
          x-on:click="view = 'after'; $dispatch('portfolio-view', { view: 'after' })"
          x-bind:class="view === 'after' ? 'opacity-100 after:origin-left after:scale-x-100' : 'opacity-55 after:origin-right after:scale-x-0'"
          class="relative cursor-pointer pb-0.5 text-xl font-medium transition-opacity duration-300 after:absolute after:-bottom-px after:left-0 after:block after:h-0.5 after:w-full after:bg-current after:transition-transform after:duration-250 after:ease-out after:content-[''] hover:opacity-100 hover:after:origin-left hover:after:scale-x-100"
        >
          {t.portfolio.after}
        </button>
      </div>
    )
  }

  <div class={`swiper ${sliderName}-swiper`}>
    <div class="swiper-wrapper">
      <slot />
    </div>

    <!-- Navigation -->
    {
      navigation && (
        <>
          <div class="absolute top-1/2 left-0 z-10 hidden h-12 w-12 -translate-y-1/2 items-center justify-center overflow-hidden rounded-full shadow-lg md:flex">
            <ButtonPrimary
              compact
              class={`nav-btn h-full w-full ${sliderName}-prev`}
              aria-label="Previous"
            >
              <Icon
                name="material-symbols-light:chevron-left"
                class="h-6 w-6"
              />
            </ButtonPrimary>
          </div>
          <div class="absolute top-1/2 right-0 z-10 hidden h-12 w-12 -translate-y-1/2 items-center justify-center overflow-hidden rounded-full shadow-lg md:flex">
            <ButtonPrimary
              compact
              class={`nav-btn h-full w-full ${sliderName}-next`}
              aria-label="Next"
            >
              <Icon
                name="material-symbols-light:chevron-right"
                class="h-6 w-6"
              />
            </ButtonPrimary>
          </div>
        </>
      )
    }
  </div>

  <!-- Pagination -->
  {pagination && <div class={`swiper-pagination ${sliderName}-pagination`} />}
</div>

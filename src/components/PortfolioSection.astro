---
import BaseSwiper from "./BaseSwiper.astro";
import { Image } from "astro:assets";
import before1Image from "/src/assets/images/before1.png";
import after1Image from "/src/assets/images/after1.png";
import before2Image from "/src/assets/images/before2.png";
import after2Image from "/src/assets/images/after2.png";
import { t } from "../i18n";
import SectionHeader from "@components/ui/SectionHeader.astro";
import SectionWrapper from "@components/ui/SectionWrapper.astro";

const projects = [
  {
    id: 1,
    images: {
      before: {
        src: before1Image,
        alt: t.portfolio.projects[0].images.before,
      },
      after: {
        src: after1Image,
        alt: t.portfolio.projects[0].images.after,
      },
    },
    info: {
      challenge: t.portfolio.projects[0].challenge,
      result: t.portfolio.projects[0].result,
    },
  },
  {
    id: 2,
    images: {
      before: {
        src: before2Image,
        alt: t.portfolio.projects[1].images.before,
      },
      after: {
        src: after2Image,
        alt: t.portfolio.projects[1].images.after,
      },
    },
    info: {
      challenge: t.portfolio.projects[1].challenge,
      result: t.portfolio.projects[1].result,
    },
  },
];
---

<SectionWrapper id="portfolio">
    <SectionHeader tag={t.portfolio.tag} title={t.portfolio.title} />
    <BaseSwiper sliderName="portfolio" beforeAfter>
      {
        projects.map((project) => (
          <div class="swiper-slide">
            <div class="project-image relative min-h-100 overflow-hidden">
              <Image
                class="image before absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 [&.active]:opacity-100"
                src={project.images.before.src}
                alt={project.images.before.alt}
                width={800}
                aria-hidden="true"
              />
              <Image
                class="image after active absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 [&.active]:opacity-100"
                src={project.images.after.src}
                alt={project.images.after.alt}
                width={1144}
                height={800}
                aria-hidden="false"
              />
            </div>
            <div class="project-info flex flex-col justify-center gap-8">
              <div class="flex flex-col gap-4">
                <h3 class="text-xl font-semibold mb-0">
                  {project.info.challenge.title}
                </h3>
                <p>{project.info.challenge.text}</p>
              </div>
              <div class="flex flex-col gap-4">
                <h3 class="text-xl font-semibold mb-0">
                  {project.info.result.title}
                </h3>
                <p>{project.info.result.text}</p>
              </div>
            </div>
          </div>
        ))
      }
    </BaseSwiper>
</SectionWrapper>

<script>
  import { initPortfolioSlider } from "@utils/portfolioSwiper";

  let cleanup = initPortfolioSlider();

  document.addEventListener("astro:after-swap", () => {
    if (cleanup) cleanup();
    cleanup = initPortfolioSlider();
  });
</script>

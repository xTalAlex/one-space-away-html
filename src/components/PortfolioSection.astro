---
import BaseSwiper from "@src/components/BaseSwiper.astro";
import SectionHeader from "@src/components/ui/SectionHeader.astro";
import SectionWrapper from "@src/components/ui/SectionWrapper.astro";
import { t } from "@src/i18n";
import { Image } from "astro:assets";

import after1Image from "/src/assets/images/after1.png";
import after2Image from "/src/assets/images/after2.png";
import before1Image from "/src/assets/images/before1.png";
import before2Image from "/src/assets/images/before2.png";

const projects = [
  {
    id: 1,
    images: {
      before: {
        src: before1Image,
        alt: t.portfolio.projects[0].images.before,
      },
      after: {
        src: after1Image,
        alt: t.portfolio.projects[0].images.after,
      },
    },
    info: {
      challenge: t.portfolio.projects[0].challenge,
      result: t.portfolio.projects[0].result,
    },
  },
  {
    id: 2,
    images: {
      before: {
        src: before2Image,
        alt: t.portfolio.projects[1].images.before,
      },
      after: {
        src: after2Image,
        alt: t.portfolio.projects[1].images.after,
      },
    },
    info: {
      challenge: t.portfolio.projects[1].challenge,
      result: t.portfolio.projects[1].result,
    },
  },
];
---

<SectionWrapper id="portfolio">
  <SectionHeader tag={t.portfolio.tag} title={t.portfolio.title} />
  <BaseSwiper sliderName="portfolio" beforeAfter>
    {
      projects.map((project) => (
        <div
          class="swiper-slide"
          x-data="{ view: 'after' }"
          x-on:portfolio-view.window="view = $event.detail.view"
        >
          <div class="project-image relative min-h-100 overflow-hidden">
            <Image
              x-show="view === 'before'"
              x-transition:enter="transition duration-300"
              x-transition:enter-start="opacity-0"
              x-transition:enter-end="opacity-100"
              class="absolute inset-0 h-full w-full object-cover"
              src={project.images.before.src}
              alt={project.images.before.alt}
              width={800}
              x-bind:aria-hidden="view !== 'before' ? 'true' : 'false'"
            />
            <Image
              x-show="view === 'after'"
              x-transition:enter="transition duration-300"
              x-transition:enter-start="opacity-0"
              x-transition:enter-end="opacity-100"
              class="absolute inset-0 h-full w-full object-cover"
              src={project.images.after.src}
              alt={project.images.after.alt}
              width={1144}
              height={800}
              x-bind:aria-hidden="view !== 'after' ? 'true' : 'false'"
            />
          </div>
          <div class="project-info flex flex-col justify-center gap-8">
            <div class="flex flex-col gap-4">
              <h3 class="mb-0 text-xl font-semibold">
                {project.info.challenge.title}
              </h3>
              <p>{project.info.challenge.text}</p>
            </div>
            <div class="flex flex-col gap-4">
              <h3 class="mb-0 text-xl font-semibold">
                {project.info.result.title}
              </h3>
              <p>{project.info.result.text}</p>
            </div>
          </div>
        </div>
      ))
    }
  </BaseSwiper>
</SectionWrapper>

<script>
  import { createSwiper } from "@src/utils/baseSwiper";

  function initPortfolioSlider() {
    const swiper = createSwiper("portfolio", {
      spaceBetween: 30,
      navigation: {
        nextEl: ".portfolio-next",
        prevEl: ".portfolio-prev",
      },
      pagination: {
        el: ".portfolio-pagination",
        clickable: true,
      },
    });

    swiper.on("slideChangeTransitionStart", () => {
      window.dispatchEvent(
        new CustomEvent("portfolio-view", { detail: { view: "after" } }),
      );
    });

    return () => swiper.destroy();
  }

  let cleanup = initPortfolioSlider();

  document.addEventListener("astro:after-swap", () => {
    if (cleanup) cleanup();
    cleanup = initPortfolioSlider();
  });
</script>
